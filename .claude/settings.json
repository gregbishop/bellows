{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-commit-bypass.sh",
            "if": "Bash(git*)",
            "statusMessage": "Checking commit gate…"
          }
        ]
      }
    ]
  }
}
